{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "lint": {},
    "test": {},
    "package:desktop": {
      "dependsOn": ["build"],
      "outputs": ["apps/desktop/dist/**", "apps/desktop/out/**"]
    }
  }
}
